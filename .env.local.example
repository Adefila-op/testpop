# Deployed Contract Addresses - Base Sepolia
VITE_FACTORY_ADDRESS=0xFd58d0f5F0423201Edb756d0f44D667106fc5705
VITE_ARTIST_SHARES_ADDRESS=0x6CCDAD96591d0Bd2e97070dD2a96E56d7ce6BC97
VITE_POAP_CAMPAIGN_ADDRESS=0x0fcb25EA06cB29296080C203119c25f9923A02ad
VITE_PRODUCT_STORE_ADDRESS=0x58BB50b4370898dED4d5d724E4A521825a4B0cE6

# Supabase Configuration
# Get these from https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# WalletConnect Project ID (required for mobile wallet connections)
# Get from https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# Admin wallet address (REQUIRED - no default fallback)
# Set this to your admin wallet address
VITE_ADMIN_WALLET=0x4B393730eFc0E3C1E0C0944fbC05EdEF4eE58092
VITE_FOUNDER_WALLET=0x4B393730eFc0E3C1E0C0944fbC05EdEF4eE58092

# RPC Endpoints (optional - will use public endpoints if not set)
# Get from Alchemy (https://www.alchemy.com) or Infura (https://www.infura.io)
# Public endpoints are rate-limited - use dedicated endpoints in production
VITE_BASE_RPC_URL=https://mainnet.base.org
VITE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

VITE_SECURE_API_BASE_URL=https://your-api.example.com
VITE_PINATA_API_BASE_URL=https://your-api.example.com/api/pinata

# Backend must issue signed JWT/session tokens carrying wallet + role claims for protected writes

# ═══════════════════════════════════════════════════════════════════════════════
# BACKEND ENVIRONMENT VARIABLES (Vercel-only, not frontend)
# ═══════════════════════════════════════════════════════════════════════════════
# Set these in Vercel Dashboard → Settings → Environment Variables
# 
# PINATA_JWT=your_pinata_jwt_here
#   - Get from https://app.pinata.cloud/developers/tokens
#   - Used by api/pinata/file.js and api/pinata/json.js
#   - Enables uploading art/metadata to IPFS
#
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_key_here
#   - Get from Supabase Dashboard → Settings → API → Service Role Key
#   - Used for direct database access in backend
#
# JWT_SECRET=your_super_secure_secret_here
#   - Use a strong random string (run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
#   - Used to sign authentication tokens in server/index.js
#
# ADMIN_WALLETS=0xaddr1,0xaddr2
#   - Comma-separated list of admin wallet addresses (lowercase, no checksums)
#   - Users with these wallets get access to /admin panel
#
# NODE_ENV=production
#
# For local development, you can set these in server/.env.local instead

