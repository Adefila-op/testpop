{
  "version": 3,
  "build": {
    "command": "npm run build:vercel",
    "outputDirectory": "dist"
  },
  "functions": {
    "server/api/index.js": {
      "runtime": "nodejs20.x",
      "maxDuration": 10,
      "memory": 512
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/api/index.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
