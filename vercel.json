{
  "version": 2,
  "routes": [
    {
      "src": "/og/share/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/share/(.*)",
      "dest": "/api/index.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
