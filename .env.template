# Environment Configuration Template

This template contains all required environment variables for the POPUP backend.
Copy this file to `.env.local` and fill in your values.

## Core Network Configuration
VITE_RPC_URL=http://localhost:8545
VITE_CHAIN_ID=31337
VITE_EXPLORER_URL=http://localhost:4000

## Smart Contract Addresses
# These are deployed contract addresses - update after deployment
VITE_PRODUCT_STORE_ADDRESS=0x0000000000000000000000000000000000000000
VITE_AUCTION_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000
VITE_PAYOUT_DISTRIBUTOR_ADDRESS=0x0000000000000000000000000000000000000000
VITE_ROYALTY_MANAGER_ADDRESS=0x0000000000000000000000000000000000000000

## Token Addresses
VITE_USDC_ADDRESS=0x0000000000000000000000000000000000000000
VITE_USDT_ADDRESS=0x0000000000000000000000000000000000000000

## Wallet Configuration
# Admin wallet for contract deployments and administration
ADMIN_PRIVATE_KEY=your_admin_private_key_here
ADMIN_PUBLIC_KEY=0x0000000000000000000000000000000000000000

# Treasury wallet for fee collection
TREASURY_WALLET=0x0000000000000000000000000000000000000000

# Creator whitelist (comma-separated, optional)
CREATOR_WHITELIST=

## Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/popup
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

## API Configuration
API_PORT=3001
API_HOST=localhost
NODE_ENV=development

# JWT Configuration for API authentication
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_EXPIRY=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

## Email Service Configuration
# For gift notifications and payout confirmations
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=your_sendgrid_key
EMAIL_FROM=noreply@popup.test

# Alternative email providers (uncomment one)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_password

## Payment Processing
# Stripe for fiat payments (optional)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

## External API Keys
# Pinata IPFS for metadata storage
PINATA_API_KEY=your_pinata_key
PINATA_API_SECRET=your_pinata_secret
PINATA_GATEWAY_URL=https://gateway.pinata.cloud

# TheGraph for indexing queries
THEGRAPH_API_KEY=your_thegraph_key

# OpenSea/Rarible/Blur API for marketplace integration
OPENSEA_API_KEY=your_opensea_key
RARIBLE_API_KEY=your_rarible_key
BLUR_API_KEY=your_blur_key

## Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json

## Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

## Contract Parameters
# Minimum bid increment in basis points (e.g., 500 = 5%)
MIN_BID_INCREMENT_BPS=500

# Auction duration in minutes
AUCTION_DURATION_MINUTES=1440

# Grace period before auction ends (5 minutes)
AUCTION_GRACE_PERIOD_MINUTES=5

# Platform fee in basis points (e.g., 250 = 2.5%)
PLATFORM_FEE_BPS=250

# Payout delay in hours (security measure)
PAYOUT_DELAY_HOURS=24

## Feature Flags
ENABLE_PAYMENTS=true
ENABLE_AUCTIONS=true
ENABLE_GIFTS=true
ENABLE_ROYALTIES=true
ENABLE_MARKETPLACE_INTEGRATION=false

## Bug Reporting and Analytics (optional)
SENTRY_DSN=
AMPLITUDE_API_KEY=
GA_TRACKING_ID=

## Testing Configuration
MOCK_EMAIL_SENDING=false
TEST_WALLET_PRIVATE_KEY=
